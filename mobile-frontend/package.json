{
  "name": "quantum-alpha-mobile-enhanced",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "react-native clean-project-auto",
    "postinstall": "test -d ios && (cd ios && pod install) || echo \"iOS folder not present, skipping pod install\"",
    "build:android": "cd android && ./gradlew assembleDebug && cd ..",
    "build:ios": "cd ios && xcodebuild -workspace QuantumAlpha.xcworkspace -scheme QuantumAlpha -configuration Debug -sdk iphonesimulator && cd ..",
    "test:e2e": "detox test",
    "test:e2e:android": "detox test -c android.emu.debug",
    "test:e2e:ios": "detox test -c ios.sim.debug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.19.3",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/netinfo": "^11.2.1",
    "@react-native-firebase/analytics": "^18.6.2",
    "@react-native-firebase/app": "^18.6.2",
    "@react-native-firebase/messaging": "^18.6.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "react": "18.2.0",
    "react-hook-form": "^7.48.2",
    "react-native": "0.72.7",
    "react-native-animatable": "^1.3.3",
    "react-native-background-fetch": "^4.3.0",
    "react-native-biometrics": "^3.0.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-device-info": "^10.11.0",
    "react-native-dotenv": "^3.4.9",
    "react-native-fast-image": "^8.6.3",
    "react-native-flipper": "^0.212.0",
    "react-native-gesture-handler": "^2.13.4",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-keychain": "^8.1.3",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal": "^13.0.1",
    "react-native-orientation-locker": "^1.5.0",
    "react-native-permissions": "^4.1.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-qrcode-scanner": "^1.5.5",
    "react-native-reanimated": "^3.5.4",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.27.0",
    "react-native-share": "^10.0.2",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-sound": "^0.11.2",
    "react-native-splash-screen": "^3.3.0",
    "react-native-super-grid": "5.0.0",
    "react-native-svg": "^14.0.0",
    "react-native-vector-icons": "^10.0.2",
    "react-native-vision-camera": "^4.7.3",
    "react-native-webview": "^13.6.4",
    "react-query": "^3.39.3",
    "yup": "^1.4.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/runtime": "^7.23.2",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
